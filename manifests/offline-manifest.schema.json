{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "packs"],
  "properties": {
    "schemaVersion": { "type": "integer" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "packId", "name", "regionType", "version", "format",
          "minZoom", "maxZoom", "bbox", "sizeBytes", "sha256", "downloadUrl"
        ],
        "properties": {
          "packId": { "type": "string" },
          "name": { "type": "string" },
          "regionType": { "type": "string" },
          "version": { "type": "string" },
          "format": { "type": "string" },
          "minZoom": { "type": "integer" },
          "maxZoom": { "type": "integer" },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": { "type": "number" }
          },
          "sizeBytes": { "type": "integer" },
          "sha256": { "type": "string" },
          "downloadUrl": { "type": "string" }
        }
      }
    }
  }
}
